# Шаблон .env — скопируй в .env и подставь свои значения. Сам .env в .gitignore.
# Мастер-ключ кошельков сюда НЕ пишем: задаётся в шелле как ZENKO_MASTER_KEY.

# Выделенный Solana RPC (Helius / Triton / QuickNode). Публичный api.mainnet-beta
# троттлит частые tx долива стамины и ограничивает пропускную способность фарма.
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# Jupiter Ultra API key for scripts/fund-stamina.js.
JUPITER_API_KEY=jup_YOUR_KEY

# Optional static HTTP(S) proxy per account. Do not commit real credentials.
# ZENKO_PROXY_MAIN=http://user:pass@main-proxy-host:8080
# ZENKO_PROXY_SPARE=http://user:pass@spare-proxy-host:8080
# Fallback for all accounts when a per-account value is not set:
# ZENKO_PROXY_URL=http://user:pass@shared-proxy-host:8080
# Fallback pool file, one proxy per line. Raw host:port:user:pass is accepted.
ZENKO_PROXY_POOL_FILE=Webshare 25 proxies.txt
